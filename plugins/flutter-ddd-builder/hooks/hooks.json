{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/plugins/flutter-ddd-builder/hooks/dart-analyze.sh\"",
            "timeout": 30,
            "statusMessage": "Analyzing Dart file..."
          }
        ]
      }
    ]
  }
}
